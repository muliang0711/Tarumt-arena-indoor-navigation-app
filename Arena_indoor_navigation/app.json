{
  "expo": {
    "name": "Arena Indoor Navigation",
    "slug": "arena-indoor-navigation",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Arena Indoor Navigation to use motion sensors for indoor positioning."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    }
  }
}
