{
  "expo": {
    "name": "Indoor Map Prototype",
    "slug": "indoor-map-prototype",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Indoor Map Prototype to access motion data for indoor position tracking."
        }
      ],
      "expo-font"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    }
  }
}
